rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Team shared files ─────────────────────────────────────────────
    match /team_files/{teamId}/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── User avatars / covers ─────────────────────────────────────────
    match /user_assets/{userId}/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Portal Templates (certificate templates uploaded by admins) ───
    match /portal-templates/{userId}/{allPaths=**} {
      allow read:   if true;                // students can preview
      allow write:  if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── Fallback: any signed-in user ──────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

  }
}
