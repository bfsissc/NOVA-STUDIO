rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles (keyed by email, not uid) ──────────────────────
    match /users/{userEmail} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == userEmail;
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      }
    }

    // ── Teams ─────────────────────────────────────────────────────────
    match /nova_teams/{teamId} {
      allow read, write: if request.auth != null;
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Invites ───────────────────────────────────────────────────────
    match /nova_invites/{token} {
      allow read, write: if request.auth != null;
    }

    // ── Sync rooms (workbook) ─────────────────────────────────────────
    match /sync_rooms/{roomId} {
      allow read, write: if request.auth != null;
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Followup Tracker ──────────────────────────────────────────────
    match /followup_sessions/{userEmail} {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
        match /colleges/{collegeId} {
          allow read, write: if request.auth != null && request.auth.token.email == userEmail;
        }
      }
    }

    match /followup_notifications/{userEmail} {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      }
    }

    // ── College Portals — PUBLIC student access ───────────────────────
    // Students are NOT logged in. They need to:
    //   1. Read the portal config
    //   2. Query & update their download record
    //   3. Submit a certificate request form
    match /college_portals/{slug} {
      // Anyone can read portal config (needed to load the student portal page)
      allow read: if true;
      // Only authenticated users (admins) can create/update the portal itself
      allow write: if request.auth != null;

      // Students subcollection — public read + update (download counter)
      match /students/{studentId} {
        allow read:   if true;
        allow create: if true;  // open-access portals create records on the fly
        allow update: if true;  // increment downloaded counter
        allow delete: if request.auth != null;
      }

      // Certificate request form — public create (students submit requests)
      match /form_requests/{reqId} {
        allow read:   if request.auth != null;
        allow create: if true;
        allow update, delete: if request.auth != null;
      }
    }

    // ── Training Partners directory ───────────────────────────────
    match /tp_directory/{tpId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      match /feedback/{fbId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Training Partner connections ───────────────────────────────
    match /tp_connections/{connId} {
      allow read, write: if request.auth != null;
    }

    // ── Nova Notifications (keyed by uid) ─────────────────────────
    match /nova_notifications/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    // Also allow writing notifications TO another user (for team alerts)
    match /nova_notifications/{uid}/items/{itemId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // ── Fallback: any other collection — authenticated users only ─────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
