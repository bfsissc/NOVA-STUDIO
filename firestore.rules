rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles (keyed by email, not uid) ──────────────────────
    // Any signed-in user can read profiles (needed for team member lookups).
    // Only the owner of the email can write their own profile.
    match /users/{userEmail} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == userEmail;

      // Sub-collections: projects, bin, meta — owner only
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      }
    }

    // ── Teams ─────────────────────────────────────────────────────────
    // Read: any signed-in user who is a member (checked in app logic).
    // Write: any signed-in user (create team / join team).
    match /nova_teams/{teamId} {
      allow read, write: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Invites ───────────────────────────────────────────────────────
    match /nova_invites/{token} {
      allow read, write: if request.auth != null;
    }

    // ── Sync rooms (workbook) ─────────────────────────────────────────
    match /sync_rooms/{roomId} {
      allow read, write: if request.auth != null;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Followup Tracker — sessions owned by email ────────────────────
    match /followup_sessions/{userEmail} {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
        match /colleges/{collegeId} {
          allow read, write: if request.auth != null && request.auth.token.email == userEmail;
        }
      }
    }

    // ── Followup Notifications — per-user inbox ───────────────────────
    match /followup_notifications/{userEmail} {
      allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.token.email == userEmail;
      }
    }

    // ── Fallback: any other collection — authenticated users only ─────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}
